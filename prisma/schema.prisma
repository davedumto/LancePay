generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  privyId          String   @unique
  email            String   @unique
  role             String   @default("freelancer")
  name             String?
  phone            String?
  avatarUrl        String?  @db.VarChar(512)
  referralCode     String?  @unique
  referredById     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  backupCodes      String[] @default([])
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  taxPercentage    Float    @default(0)
  timezone         String?
  virtualAccount         VirtualAccount?
  wallet                 Wallet?
  bankAccounts           BankAccount[]
  contacts               Contact[]
  invoices               Invoice[]
  clientInvoices         Invoice[]             @relation("ClientInvoices")
  paymentMethods         PaymentMethod[]
  transactions           Transaction[]
  reminderSettings       ReminderSettings?
  autoSwapRule           AutoSwapRule?
  referredBy             User?                 @relation("UserReferrals", fields: [referredById], references: [id])
  referrals              User[]                @relation("UserReferrals")
  referralEarnings       ReferralEarning[]     @relation("ReferrerEarnings")
  earningsFromMe         ReferralEarning[]     @relation("ReferredUserEarnings")
  paymentAdvances        PaymentAdvance[]
  apiKeys                ApiKey[]
  brandingSettings       BrandingSettings?
  webhooks               UserWebhook[]
  userBadges             UserBadge[]
  auditEvents            AuditEvent[]
  savingsGoals           SavingsGoal[]
  incomeVerifications    IncomeVerification[]
  payoutBatches          PayoutBatch[]
  manualPayments         ManualPayment[]       @relation("ManualPaymentVerifier")
  collaborations         InvoiceCollaborator[] @relation("SubContractorCollaborations")
  trustScore             UserTrustScore?
  walletSigners          WalletSigner[]
  multisigProposals      MultisigProposal[]    @relation("MultisigProposer")
  proposalSignatures     ProposalSignature[]
  withdrawalTransactions WithdrawalTransaction[]
  anchorSessions         AnchorSession[]
  expenses              Expense[]
  subscriptions         Subscription[]
  notifications         Notification[]
  tags                  Tag[]
  timeEntries             TimeEntry[]
  sessions                UserSession[]
  sanctionsScreening      SanctionsScreening?
  deletionRequests        AccountDeletionRequest[]
  kycApplication          KycApplication?
  kycDocuments            KycDocument[]
  whitelistAddresses      WhitelistAddress[]
}

model KycApplication {
  id              String   @id @default(uuid())
  userId          String   @unique
  status          String   @default("pending") @db.VarChar(20)
  level           String   @default("basic") @db.VarChar(20)
  fullName        String?  @db.VarChar(200)
  dateOfBirth     DateTime?
  countryCode     String?  @db.VarChar(2)
  addressLine1    String?  @db.VarChar(200)
  addressLine2    String?  @db.VarChar(200)
  city            String?  @db.VarChar(100)
  region          String?  @db.VarChar(100)
  postalCode      String?  @db.VarChar(20)
  rejectionReason String?  @db.Text
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model KycDocument {
  id           String   @id @default(uuid())
  userId       String
  documentType String   @db.VarChar(40)
  status       String   @default("uploaded") @db.VarChar(20)
  fileUrl      String   @db.VarChar(512)
  fileName     String?  @db.VarChar(200)
  fileSize     Int?
  mimeType     String?  @db.VarChar(80)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([documentType])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // e.g. "invoice_paid", "withdrawal_complete", "system"
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  address   String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isVerified    Boolean  @default(false)
  isDefault     Boolean  @default(false)
  nickname      String?  @db.VarChar(32)
  createdAt     DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id])
  withdrawals   Transaction[]  @relation("WithdrawalBank")
  autoSwapRules AutoSwapRule[]
}

model Contact {
  id        String    @id @default(uuid())
  userId    String
  name      String
  email     String
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  bankName      String   @db.VarChar(100)
  accountNumber String   @unique @db.VarChar(20)
  accountName   String   @db.VarChar(255)
  provider      String   @db.VarChar(50)
  providerRef   String?  @db.VarChar(255)
  status        String   @default("active") @db.VarChar(20)
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("VirtualAccountDeposits")

  @@index([userId])
  @@index([accountNumber])
  @@index([provider])
  @@index([status])
}

model Invoice {
  id            String    @id @default(uuid())
  userId        String
  invoiceNumber String    @unique
  clientEmail   String
  clientName    String?
  description   String
  amount        Decimal   @db.Decimal(10, 2)
  currency      String    @default("USD")
  status        String    @default("pending")
  paymentLink   String    @unique
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user                    User                  @relation(fields: [userId], references: [id])
  clientId                String?
  client                  User?                 @relation("ClientInvoices", fields: [clientId], references: [id])
  transaction             Transaction?
  paymentReminders        PaymentReminder[]
  dispute                 Dispute?
  collaborators           InvoiceCollaborator[]
  escrowEnabled           Boolean               @default(false)
  escrowStatus            String                @default("none")
  escrowContractId        String?               @unique
  escrowReleaseConditions String?

  escrowReleasedAt        DateTime?
  escrowDisputedAt        DateTime?
  escrowEvents            EscrowEvent[]
  invoiceTags             InvoiceTag[]
  timeEntries             TimeEntry[]
  lienActive              Boolean               @default(false)
  advances                PaymentAdvance[]
  auditEvents             AuditEvent[]
  isConfidential          Boolean               @default(false)
  encryptedPayload        String?               @db.Text
  decryptionSalt          String?
  messages                InvoiceMessage[]
  manualPayments          ManualPayment[]
  cancelledAt             DateTime?
  cancellationReason      String?
  doNotAutoCancel         Boolean               @default(false)

  subscriptionId          String?
  subscription            Subscription?         @relation(fields: [subscriptionId], references: [id])
}

model Subscription {
  id                 String   @id @default(uuid())
  userId             String
  clientEmail        String
  clientName         String?
  description        String
  amount             Decimal  @db.Decimal(10, 2)
  currency           String   @default("USD")
  frequency          String   @default("monthly")
  interval           Int      @default(1)
  status             String   @default("active")
  nextGenerationDate DateTime
  lastGeneratedAt    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@index([nextGenerationDate])
}

model InvoiceMessage {
  id            String   @id @default(uuid())
  invoiceId     String
  senderId      String?
  senderType    String
  senderName    String
  content       String   @db.Text
  attachmentUrl String?  @db.VarChar(512)
  isInternal    Boolean  @default(false)
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([createdAt])
}

model PaymentReminder {
  id           String   @id @default(uuid())
  invoiceId    String
  reminderType String
  daysOffset   Int?
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ReminderSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  enabled       Boolean  @default(true)
  beforeDueDays Int[]    @default([3, 1])
  onDueEnabled  Boolean  @default(true)
  afterDueDays  Int[]    @default([1, 3, 7])
  customMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String    @id @default(uuid())
  userId            String
  type              String
  status            String    @default("pending")
  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @default("USD")
  ngnAmount         Decimal?  @db.Decimal(15, 2)
  exchangeRate      Decimal?  @db.Decimal(10, 4)
  invoiceId         String?   @unique
  bankAccountId     String?
  txHash            String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  autoSwapTriggered Boolean   @default(false)
  error             String?
  externalId        String?   @unique
  virtualAccountId  String?

  user           User            @relation(fields: [userId], references: [id])
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id])
  bankAccount    BankAccount?    @relation("WithdrawalBank", fields: [bankAccountId], references: [id])
  virtualAccount VirtualAccount? @relation("VirtualAccountDeposits", fields: [virtualAccountId], references: [id])

  @@index([status])
  @@index([type])
  @@index([bankAccountId])
}

model ReferralEarning {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String
  invoiceId      String
  amountUsdc     Decimal  @db.Decimal(18, 6)
  platformFee    Decimal  @db.Decimal(18, 6)
  status         String   @default("earned")
  createdAt      DateTime @default(now())

  referrer     User @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferredUserEarnings", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredUserId])
  @@index([createdAt])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHint    String
  hashedKey  String    @unique
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hashedKey])
}

model AutoSwapRule {
  id            String   @id @default(uuid())
  userId        String   @unique
  percentage    Int
  bankAccountId String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
}

model BulkInvoiceJob {
  id           String    @id @default(uuid())
  userId       String
  status       String    @default("processing")
  totalCount   Int
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  results      Json      @default("[]")
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([userId])
}

model Dispute {
  id              String    @id @default(uuid())
  invoiceId       String    @unique
  initiatedBy     String
  initiatorEmail  String
  reason          String
  requestedAction String
  status          String    @default("open")
  resolution      String?
  resolvedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  invoice  Invoice          @relation(fields: [invoiceId], references: [id])
  messages DisputeMessage[]

  @@index([invoiceId])
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String
  senderType  String
  senderEmail String
  message     String
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model EscrowEvent {
  id         String   @id @default(uuid())
  invoiceId  String
  eventType  String
  actorType  String
  actorEmail String
  notes      String?
  metadata   Json?    @default("{}")
  createdAt  DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model BrandingSettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  logoUrl      String?
  primaryColor String   @default("#000000")
  footerText   String?
  signatureUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserWebhook {
  id               String    @id @default(uuid())
  userId           String
  targetUrl        String    @db.VarChar(512)
  signingSecret    String    @db.VarChar(255)
  description      String?   @db.VarChar(100)
  isActive         Boolean   @default(true)
  subscribedEvents String[]  @default(["invoice.paid"])
  lastTriggeredAt  DateTime?
  createdAt        DateTime  @default(now())

  // Retry/status tracking
  status              String    @default("ACTIVE") @db.VarChar(20)
  consecutiveFailures Int       @default(0)
  lastFailureAt       DateTime?

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
  @@index([status])
}

model WebhookDelivery {
  id             String    @id @default(uuid())
  webhookId      String
  eventType      String    @db.VarChar(50)
  payload        String    @db.Text
  status         String    @default("pending") @db.VarChar(20)
  attemptCount   Int       @default(0)
  lastAttemptAt  DateTime?
  nextRetryAt    DateTime?
  lastStatusCode Int?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  webhook UserWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

model PaymentAdvance {
  id                      String    @id @default(uuid())
  userId                  String
  invoiceId               String
  requestedAmountUSDC     Decimal   @db.Decimal(10, 2)
  advancedAmountUSDC      Decimal   @db.Decimal(10, 2)
  advancedAmountNGN       Decimal   @db.Decimal(15, 2)
  exchangeRate            Decimal   @db.Decimal(10, 4)
  feePercentage           Decimal   @default(2.00) @db.Decimal(5, 2)
  feeAmountUSDC           Decimal   @db.Decimal(10, 2)
  totalRepaymentUSDC      Decimal   @db.Decimal(10, 2)
  status                  String    @default("pending")
  yellowCardTransactionId String?
  disbursedAt             DateTime?
  repaidAt                DateTime?
  error                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceId])
}

model AuditEvent {
  id        String   @id @default(uuid())
  invoiceId String
  eventType String   @db.VarChar(50)
  actorId   String?
  metadata  Json?
  signature String
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([invoiceId])
  @@index([eventType])
  @@index([createdAt])
}

model SavingsGoal {
  id                String   @id @default(uuid())
  userId            String
  title             String   @db.VarChar(100)
  targetAmountUsdc  Decimal  @db.Decimal(18, 6)
  currentAmountUsdc Decimal  @default(0) @db.Decimal(18, 6)
  savingsPercentage Int
  isActive          Boolean  @default(true)
  status            String   @default("in_progress")
  isTaxVault        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model UserTrustScore {
  id                 String   @id @default(uuid())
  userId             String   @unique
  score              Int      @default(50)
  totalVolumeUsdc    Decimal  @db.Decimal(18, 6) @default(0)
  disputeCount       Int      @default(0)
  successfulInvoices Int      @default(0)
  lastUpdatedAt      DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClientReputation {
  id            String   @id @default(uuid())
  clientEmail   String   @unique @map("client_email")
  domainType    String?  @map("domain_type")
  paymentScore  Int      @default(0) @map("payment_score")
  isVerified    Boolean  @default(false) @map("is_verified")
  lastCheckedAt DateTime @default(now()) @map("last_checked_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([clientEmail])
  @@map("client_reputations")
}

model BadgeDefinition {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(100)
  description      String?
  criteriaJson     Json
  imageUrl         String?  @db.VarChar(512)
  stellarAssetCode String   @unique @db.VarChar(12)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id            String   @id @default(uuid())
  userId        String
  badgeId       String
  stellarTxHash String   @db.VarChar(255)
  issuedAt      DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model IncomeVerification {
  id            String   @id @default(uuid())
  userId        String
  tokenHash     String   @unique
  recipientName String?
  expiresAt     DateTime
  accessCount   Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RiskAssessment {
  id         String   @id @default(uuid())
  entityType String   @db.VarChar(20)
  entityId   String
  riskScore  Int
  signals    Json?
  status     String   @default("logged") @db.VarChar(20)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([riskScore])
  @@index([status])
  @@index([createdAt])
}

model SecurityWatchlist {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(20)
  value     String   @unique @db.VarChar(255)
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([type])
  @@index([value])
}

model InvoiceCollaborator {
  id              String    @id @default(uuid())
  invoiceId       String
  subContractorId String
  sharePercentage Decimal   @db.Decimal(5, 2)
  payoutStatus    String    @default("pending") @db.VarChar(20)
  internalTxId    String?   @db.VarChar(255)
  paidAt          DateTime?
  paymentSource   String?   // 'payment' | 'escrow' | 'advance'
  createdAt       DateTime  @default(now())

  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  subContractor User    @relation("SubContractorCollaborations", fields: [subContractorId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, subContractorId])
  @@index([invoiceId])
  @@index([subContractorId])
  @@index([payoutStatus])
}

model PayoutBatch {
  id              String    @id @default(uuid())
  userId          String
  status          String    @default("pending")
  totalAmount     Decimal   @db.Decimal(18, 6)
  totalRecipients Int
  successCount    Int       @default(0)
  failedCount     Int       @default(0)
  results         Json      @default("[]")
  scheduledAt     DateTime? // optional timestamp when payout should be executed
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  items       PayoutItem[]

  @@index([userId])
  @@index([status])
}

model ManualPayment {
  id            String    @id @default(uuid())
  invoiceId     String
  amountPaid    Decimal   @db.Decimal(15, 2)
  currency      String    @default("NGN")
  paymentMethod String    @db.VarChar(50)
  receiptUrl    String?   @db.VarChar(512)
  notes         String?   @db.Text
  status        String    @default("pending")
  verifiedBy    String?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  verifier User?   @relation("ManualPaymentVerifier", fields: [verifiedBy], references: [id])

  @@index([invoiceId])
  @@index([status])
  @@index([verifiedBy])
}

model Expense {
  id          String   @id @default(uuid())
  userId       String
  category     String   @db.VarChar(50)
  description  String   @db.VarChar(255)
  amount       Decimal  @db.Decimal(18, 6)
  currency     String   @default("USDC") @db.VarChar(10)
  receiptUrl   String?  @db.VarChar(512)
  notes        String?  @db.Text
  expenseDate  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([expenseDate])
  @@index([createdAt])
}

model WithdrawalTransaction {
  id                String    @id @default(uuid())
  userId            String
  anchorId          String    @db.VarChar(50) // 'moneygram' | 'yellowcard'
  stellarTxId       String?   @db.VarChar(255) // SEP-24 transaction ID from anchor
  stellarTxHash     String?   @db.VarChar(255) // On-chain transaction hash
  amount            Decimal   @db.Decimal(18, 7)
  asset             String    @default("USDC") @db.VarChar(12)
  status            String    @default("pending") @db.VarChar(20) // pending, interactive, submitted, completed, failed
  interactiveUrl    String?   @db.Text // Anchor's interactive URL
  withdrawAddress   String?   @db.VarChar(56) // Anchor's Stellar address to send to
  withdrawMemo      String?   @db.VarChar(255) // Memo for payment to anchor
  withdrawMemoType  String?   @db.VarChar(10) // text, id, hash
  withdrawType      String    @default("bank_transfer") @db.VarChar(20) // bank_transfer, cash
  error             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stellarTxId])
  @@index([anchorId])
  @@index([createdAt])
}

model AnchorSession {
  id          String   @id @default(uuid())
  userId      String
  anchorId    String   @db.VarChar(50) // 'moneygram' | 'yellowcard'
  jwtToken    String   @db.Text
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, anchorId])
  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model CollectiveWallet {
  id                 String   @id @default(uuid())
  name               String   @db.VarChar(100)
  stellarAddress     String   @unique @db.VarChar(56)
  encryptedSecretKey String?  @db.Text
  threshold          Int      @default(2)
  createdAt          DateTime @default(now())

  signers   WalletSigner[]
  proposals MultisigProposal[]

  @@index([stellarAddress])
}

model WalletSigner {
  id       String @id @default(uuid())
  walletId String
  userId   String
  weight   Int    @default(1)
  createdAt DateTime @default(now())

  wallet CollectiveWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([walletId, userId])
  @@index([walletId])
  @@index([userId])
}

model MultisigProposal {
  id                  String    @id @default(uuid())
  walletId            String
  proposerId          String
  destinationAddress  String    @db.VarChar(255)
  amountUsdc          Decimal   @db.Decimal(18, 6)
  memo                String?   @db.Text
  status              String    @default("pending") @db.VarChar(20)
  expiresAt           DateTime
  executedAt          DateTime?
  executionStartedAt  DateTime?
  stellarTxHash       String?   @db.VarChar(255)
  lastError           String?   @db.Text
  createdAt           DateTime  @default(now())

  wallet   CollectiveWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  proposer User                @relation("MultisigProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  signatures ProposalSignature[]

  @@index([walletId])
  @@index([proposerId])
  @@index([status])
  @@index([expiresAt])
}

model ProposalSignature {
  id         String   @id @default(uuid())
  proposalId String
  signerId   String
  createdAt  DateTime @default(now())

  proposal MultisigProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  signer   User             @relation(fields: [signerId], references: [id], onDelete: Cascade)

  @@unique([proposalId, signerId])
  @@index([proposalId])
  @@index([signerId])
}

model PayoutItem {
  id                  String   @id @default(uuid())
  batchId             String
  recipientIdentifier String
  amount              Decimal  @db.Decimal(18, 6)
  payoutType          String   @db.VarChar(20)
  status              String   @default("pending") @db.VarChar(20)
  txHash              String?  @db.VarChar(255)
  errorMessage        String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  batch PayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
}

model PaymentMethod {
  id        String   @id @default(uuid())
  userId    String
  type      String   // e.g., "stellar_wallet", "bank_account"
  name      String?  // e.g., "Main Ledger", "Personal Savings"
  value     String   // e.g., Stellar address
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Tag {
  id        String   @id @default(uuid())
  userId    String
  name      String   @db.VarChar(50)
  color     String   @default("#6366f1") @db.VarChar(7)
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceTags InvoiceTag[]

  @@unique([userId, name])
  @@index([userId])
}

model InvoiceTag {
  id        String   @id @default(uuid())
  invoiceId String
  tagId     String
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, tagId])
  @@index([invoiceId])
  @@index([tagId])
}

/// A logged unit of billable time for a freelancer / contractor.
model TimeEntry {
  id          String   @id @default(uuid())
  userId      String
  invoiceId   String?
  description String   @db.VarChar(500)
  hours       Decimal  @db.Decimal(10, 2)
  rateUsdc    Decimal  @db.Decimal(18, 6)
  occurredOn  DateTime @db.Date
  status      String   @default("draft") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([invoiceId])
  @@index([userId, occurredOn])
  @@index([status])
}

/// Active authentication sessions surfaced to the user.
model UserSession {
  id           String    @id @default(uuid())
  userId       String
  deviceLabel  String?   @db.VarChar(100)
  userAgent    String?   @db.VarChar(500)
  ipAddress    String?   @db.VarChar(45)
  tokenHint    String?   @db.VarChar(12)
  issuedAt     DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([lastSeenAt])
}

/// Latest sanctions / PEP screening result for a user. One row per user;
/// rescreens overwrite the row in place. Detailed history lives off-platform
/// at the screening provider so the API can stay slim.
model SanctionsScreening {
  id          String   @id @default(uuid())
  userId      String   @unique
  status      String   @db.VarChar(20) // "clear" | "flagged" | "under_review"
  provider    String   @db.VarChar(50) // e.g. "ComplyAdvantage", "manual"
  matchScore  Float?   // 0..1, null when status is "clear" with no match
  screenedAt  DateTime @default(now())
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([screenedAt])
}

model ClientNote {
  id        String   @id @default(uuid())
  userId    String
  clientId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  client User @relation("ClientNotes", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
}

model SavedFilter {
  id          String   @id @default(uuid())
  userId      String
  name        String   @db.VarChar(100)
  entityType  String   @db.VarChar(50) // 'invoice', 'transaction', 'client', etc.
  filters     Json     // JSON object representing the filter criteria
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([entityType])
}

/// Pending account-deletion request raised by the user. We keep the row for
/// the duration of the grace window so support can cancel the deletion if
/// the user changes their mind. Status moves "pending" → "cancelled" |
/// "completed" depending on the outcome.
model AccountDeletionRequest {
  id          String   @id @default(uuid())
  userId      String
  reason      String?  @db.VarChar(500)
  status      String   @default("pending") @db.VarChar(20)
  scheduledAt DateTime // when the soft-delete is eligible to execute
  cancelledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([status])
  @@index([scheduledAt])
}

/// Snapshot of an FX pair's mid rate at a point in time. Rates are written
/// by the scheduled exchange-rate poller; the historical endpoint reads
/// from this table so on-chain settlement, FX hedging audits, and admin
/// dashboards all see the same numbers.
model FxRateSnapshot {
  id           String   @id @default(uuid())
  fromCurrency String   @db.VarChar(8)
  toCurrency   String   @db.VarChar(8)
  rate         Decimal  @db.Decimal(18, 8)
  source       String   @db.VarChar(50) // e.g. "exchangerate-api", "manual"
  capturedAt   DateTime
  createdAt    DateTime @default(now())

  @@index([fromCurrency, toCurrency, capturedAt])
  @@index([capturedAt])
}

/// A client project grouping invoices and time entries.
model Project {
  id          String    @id @default(uuid())
  userId      String
  title       String    @db.VarChar(200)
  description String?   @db.Text
  clientName  String?   @db.VarChar(200)
  status      String    @default("active") @db.VarChar(20) // "active" | "archived"
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/// A tax rate definition that can be applied to invoices.
model TaxRate {
  id          String   @id @default(uuid())
  userId      String
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(300)
  rate        Decimal  @db.Decimal(6, 4) // e.g. 0.1000 for 10%
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A whitelisted Stellar/bank withdrawal address for a user.
model WhitelistAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String   @db.VarChar(100)
  address   String   @db.VarChar(70)
  network   String   @default("stellar") @db.VarChar(20) // "stellar" | "bank"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([userId])
}
